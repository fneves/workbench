#!/usr/bin/env bash
set -euo pipefail

# wb-status: Orchestrator TUI dashboard with visual notifications
# Shows all active tasks with live diff stats, an alert bar, and event log

WORKBENCH_STATE_DIR="/tmp/workbench"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Colors ──────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'
REVERSE='\033[7m'
BLINK='\033[5m'

# Background colors for the alert bar
BG_GREEN='\033[42m'
BG_YELLOW='\033[43m'
BG_RED='\033[41m'
BG_BLUE='\033[44m'
BG_PURPLE='\033[45m'
FG_BLACK='\033[30m'

# ── State ───────────────────────────────────────────────────
SELECTED=0
TASK_BRANCHES=()
declare -A LAST_STATUS

# Event log: circular buffer of recent events (newest first)
EVENT_LOG=()
MAX_EVENTS=8

# Alert bar state
ALERT_MSG=""
ALERT_COLOR=""
ALERT_EXPIRES=0     # epoch second when alert clears
ALERT_FLASH=false   # whether to blink the bar

# Spinner frames for running tasks
SPINNER_FRAMES=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
TICK=0

# ── Helpers ─────────────────────────────────────────────────

push_event() {
    local icon="$1" msg="$2"
    local ts
    ts="$(date +%H:%M:%S)"
    EVENT_LOG=("${ts} ${icon} ${msg}" "${EVENT_LOG[@]}")
    # Trim to max
    if [[ ${#EVENT_LOG[@]} -gt $MAX_EVENTS ]]; then
        EVENT_LOG=("${EVENT_LOG[@]:0:$MAX_EVENTS}")
    fi
}

set_alert() {
    local msg="$1" color="$2" duration="${3:-5}" flash="${4:-false}"
    ALERT_MSG="$msg"
    ALERT_COLOR="$color"
    ALERT_EXPIRES=$(( $(date +%s) + duration ))
    ALERT_FLASH="$flash"
}

get_tasks() {
    TASK_BRANCHES=()
    if [[ -d "$WORKBENCH_STATE_DIR" ]]; then
        for f in "$WORKBENCH_STATE_DIR"/*.json; do
            [[ -f "$f" ]] || continue
            TASK_BRANCHES+=("$(basename "$f" .json)")
        done
    fi
}

# ── Render ──────────────────────────────────────────────────

render() {
    clear
    local cols rows
    cols=$(tput cols 2>/dev/null || echo 80)
    rows=$(tput lines 2>/dev/null || echo 24)

    TICK=$(( (TICK + 1) % ${#SPINNER_FRAMES[@]} ))
    local spinner="${SPINNER_FRAMES[$TICK]}"
    local now
    now=$(date +%s)

    # ── Alert bar (full width, colored background) ──────────
    if [[ -n "$ALERT_MSG" ]] && [[ $now -lt $ALERT_EXPIRES ]]; then
        local bar_text="  $ALERT_MSG"
        local padding=$(( cols - ${#bar_text} - 1 ))
        [[ $padding -lt 0 ]] && padding=0
        local pad_str
        pad_str="$(printf '%*s' "$padding" '')"

        if [[ "$ALERT_FLASH" == true ]] && [[ $(( now % 2 )) -eq 0 ]]; then
            # Flash: alternate between colored and normal
            echo -e "${ALERT_COLOR}${FG_BLACK}${BOLD}${bar_text}${pad_str}${NC}"
        else
            echo -e "${ALERT_COLOR}${FG_BLACK}${BOLD}${bar_text}${pad_str}${NC}"
        fi
    else
        ALERT_MSG=""
        # Empty line to maintain layout consistency
        echo ""
    fi

    # ── Header ──────────────────────────────────────────────
    echo -e "  ${PURPLE}${BOLD}⚡ workbench${NC}  ${DIM}orchestrator${NC}"
    local repo_path
    repo_path="$(cat "$WORKBENCH_STATE_DIR/.repo" 2>/dev/null || echo "no repo")"
    repo_path="$(basename "$repo_path")"
    echo -e "  ${DIM}$(date +"%a %b %d %H:%M:%S") · $repo_path${NC}"
    echo ""

    # ── Task table ──────────────────────────────────────────
    printf "  ${DIM}%-3s  %-30s %-12s %7s %7s %6s  %-8s${NC}\n" \
        "#" "BRANCH" "STATUS" "ADDED" "REMOVED" "FILES" "AGENT"
    echo -e "  ${DIM}$(printf '─%.0s' $(seq 1 $((cols - 4))))${NC}"

    get_tasks

    if [[ ${#TASK_BRANCHES[@]} -eq 0 ]]; then
        echo ""
        echo -e "  ${DIM}No active tasks. Press ${NC}${CYAN}n${NC}${DIM} to spawn one.${NC}"
        echo ""
    else
        local idx=0
        for branch in "${TASK_BRANCHES[@]}"; do
            local state_file="$WORKBENCH_STATE_DIR/$branch.json"
            [[ -f "$state_file" ]] || continue

            local status added removed files agent mode
            status="$(jq -r '.status // "unknown"' "$state_file")"
            added="$(jq -r '.diff_added // 0' "$state_file")"
            removed="$(jq -r '.diff_removed // 0' "$state_file")"
            files="$(jq -r '.diff_files // 0' "$state_file")"
            agent="$(jq -r '.agent // "?"' "$state_file")"
            mode="$(jq -r '.mode // "worktree"' "$state_file")"

            # ── Status icon (animated for running) ──────────
            local status_display icon status_color
            case "$status" in
                running)    icon="${spinner}"; status_color="$GREEN" ;;
                prompting)  icon="◉"; status_color="$YELLOW" ;;
                done)       icon="✓"; status_color="$CYAN" ;;
                failed)     icon="✗"; status_color="$RED" ;;
                starting)   icon="◔"; status_color="$BLUE" ;;
                *)          icon="?"; status_color="$DIM" ;;
            esac

            status_display="${status_color}${icon} ${status}${NC}"

            # Mode badge
            local mode_badge=""
            [[ "$mode" == "container" ]] && mode_badge=" ${DIM}[ctr]${NC}"

            # ── State transition detection ──────────────────
            local prev="${LAST_STATUS[$branch]:-}"
            if [[ "$status" != "$prev" ]] && [[ -n "$prev" ]]; then
                case "$status" in
                    done)
                        push_event "${CYAN}✓${NC}" "${branch} — agent finished"
                        set_alert "  ✓ ${branch} finished — ready for review" "$BG_GREEN" 6 true
                        printf "\a"  # bell
                        # Also fire native notification
                        if command -v wb-notify &>/dev/null; then
                            wb-notify "✓ $branch" "Agent finished successfully" "Glass" "workbench-$branch" &
                        fi
                        ;;
                    prompting)
                        push_event "${YELLOW}◉${NC}" "${branch} — waiting for input"
                        set_alert "  ◉ ${branch} needs your attention" "$BG_YELLOW" 8 true
                        printf "\a"
                        if command -v wb-notify &>/dev/null; then
                            wb-notify "⏳ $branch" "Agent is waiting for input" "Ping" "workbench-$branch" &
                        fi
                        ;;
                    failed)
                        push_event "${RED}✗${NC}" "${branch} — agent failed"
                        set_alert "  ✗ ${branch} failed" "$BG_RED" 10 true
                        printf "\a"
                        if command -v wb-notify &>/dev/null; then
                            wb-notify "✗ $branch" "Agent failed" "Basso" "workbench-$branch" &
                        fi
                        ;;
                    running)
                        push_event "${GREEN}●${NC}" "${branch} — agent started"
                        ;;
                esac
            fi
            LAST_STATUS["$branch"]="$status"

            # ── Row highlight ───────────────────────────────
            local prefix="  "
            local suffix=""
            if [[ $idx -eq $SELECTED ]]; then
                prefix="  ${REVERSE}"
                suffix="${NC}"
            fi

            # Flash the row if it just transitioned to an attention state
            if [[ "$status" == "prompting" ]] || [[ "$status" == "failed" ]]; then
                if [[ $(( now % 2 )) -eq 0 ]] && [[ $idx -ne $SELECTED ]]; then
                    prefix="  ${status_color}"
                    suffix="${NC}"
                fi
            fi

            printf "${prefix}%-3s  %-30s %-22b ${GREEN}%+7s${NC} ${RED}%7s${NC} %5s  ${DIM}%-8s${NC}${suffix}\n" \
                "$((idx + 1))" \
                "${branch:0:28}${mode_badge}" \
                "$status_display" \
                "+$added" \
                "-$removed" \
                "$files" \
                "$agent"

            idx=$((idx + 1))
        done
    fi

    # ── Controls ────────────────────────────────────────────
    echo ""
    echo -e "  ${DIM}$(printf '─%.0s' $(seq 1 $((cols - 4))))${NC}"
    echo -e "  ${CYAN}n${NC} new task   ${CYAN}↑↓${NC} select   ${CYAN}enter${NC} jump to tab   ${CYAN}d${NC} global diff   ${CYAN}k${NC} kill   ${CYAN}q${NC} quit"

    # ── Event log ───────────────────────────────────────────
    if [[ ${#EVENT_LOG[@]} -gt 0 ]]; then
        echo ""
        echo -e "  ${BOLD}Events${NC}"
        local show_count=${#EVENT_LOG[@]}
        # Limit to what fits on screen (rough estimate)
        local avail=$(( rows - 18 - ${#TASK_BRANCHES[@]} ))
        [[ $avail -lt 2 ]] && avail=2
        [[ $show_count -gt $avail ]] && show_count=$avail

        for (( i=0; i<show_count; i++ )); do
            local evt="${EVENT_LOG[$i]}"
            # Dim older events
            if [[ $i -eq 0 ]]; then
                echo -e "    ${evt}"
            else
                echo -e "    ${DIM}${evt}${NC}"
            fi
        done
    fi
}

# ── Actions ─────────────────────────────────────────────────

spawn_interactive() {
    echo ""
    echo -ne "  ${CYAN}Branch name: ${NC}"
    read -r branch_name
    if [[ -z "$branch_name" ]]; then
        return
    fi

    echo -ne "  ${CYAN}Task prompt (empty for interactive): ${NC}"
    read -r prompt

    echo -ne "  ${CYAN}Agent [claude/opencode] (default: claude): ${NC}"
    read -r agent
    agent="${agent:-claude}"

    echo -ne "  ${CYAN}Mode [worktree/container] (default: worktree): ${NC}"
    read -r mode
    mode="${mode:-worktree}"

    echo -ne "  ${CYAN}Base branch (default: main): ${NC}"
    read -r base
    base="${base:-main}"

    local cmd="$SCRIPT_DIR/wb-spawn -b '$branch_name' -a '$agent' -m '$mode' -f '$base'"
    if [[ -n "$prompt" ]]; then
        cmd="$cmd -p '$prompt'"
    else
        cmd="$cmd -i"
    fi

    eval "$cmd"

    push_event "${GREEN}+${NC}" "Spawned ${branch_name} (${agent}, ${mode})"
    set_alert "  + Spawned ${branch_name}" "$BG_BLUE" 4 false
    sleep 1
}

jump_to_tab() {
    if [[ ${#TASK_BRANCHES[@]} -eq 0 ]]; then
        return
    fi
    local branch="${TASK_BRANCHES[$SELECTED]}"

    if [[ -n "${ZELLIJ:-}" ]]; then
        zellij action go-to-tab-name "$branch" 2>/dev/null || {
            local tab_idx=$((SELECTED + 2))
            zellij action go-to-tab "$tab_idx" 2>/dev/null || true
        }
    fi
}

kill_task() {
    if [[ ${#TASK_BRANCHES[@]} -eq 0 ]]; then
        return
    fi
    local branch="${TASK_BRANCHES[$SELECTED]}"
    echo ""
    echo -ne "  ${RED}Kill task '$branch'? [y/N]: ${NC}"
    read -rsn1 confirm
    echo ""
    if [[ "$confirm" == "y" ]] || [[ "$confirm" == "Y" ]]; then
        "$SCRIPT_DIR/wb-cleanup" "$branch"
        push_event "${RED}×${NC}" "Killed ${branch}"
        set_alert "  × Killed ${branch}" "$BG_RED" 3 false
        SELECTED=0
        unset "LAST_STATUS[$branch]"
        sleep 1
    fi
}

global_diff() {
    local all_files=""
    for branch in "${TASK_BRANCHES[@]}"; do
        local sf="$WORKBENCH_STATE_DIR/$branch.json"
        [[ -f "$sf" ]] || continue
        local wt
        wt="$(jq -r '.worktree' "$sf")"
        if [[ -d "$wt" ]]; then
            local files
            files="$(cd "$wt" && git diff --name-only HEAD 2>/dev/null | sed "s|^|$branch: |")"
            if [[ -n "$files" ]]; then
                all_files+="$files"$'\n'
            fi
        fi
    done

    if [[ -z "$all_files" ]]; then
        set_alert "  No changes across any worktree" "$BG_PURPLE" 3 false
        return
    fi

    if command -v fzf &>/dev/null; then
        local selected
        selected="$(echo "$all_files" | fzf \
            --header="Global diff — select file (ESC to cancel)" \
            --preview='
                branch=$(echo {} | cut -d: -f1)
                file=$(echo {} | cut -d" " -f2-)
                sf="/tmp/workbench/$branch.json"
                wt=$(jq -r ".worktree" "$sf")
                cd "$wt" && git diff HEAD --color -- "$file"
            ' \
            --preview-window=right:60%:wrap \
            2>/dev/null)" || return 0

        if [[ -n "$selected" ]]; then
            local branch file wt
            branch="$(echo "$selected" | cut -d: -f1)"
            file="$(echo "$selected" | cut -d' ' -f2-)"
            wt="$(jq -r '.worktree' "$WORKBENCH_STATE_DIR/$branch.json")"

            if [[ -n "${ZELLIJ:-}" ]]; then
                if command -v delta &>/dev/null; then
                    zellij run --floating --name "diff: $branch/$file" -- \
                        bash -c "cd '$wt' && git diff HEAD -- '$file' | delta --paging always"
                else
                    zellij run --floating --name "diff: $branch/$file" -- \
                        bash -c "cd '$wt' && git diff HEAD -- '$file' --color | less -R"
                fi
            fi
        fi
    else
        set_alert "  Install fzf for global diff browsing" "$BG_YELLOW" 4 false
    fi
}

dismiss_alert() {
    ALERT_MSG=""
    ALERT_EXPIRES=0
}

# ── Main loop ───────────────────────────────────────────────
# Faster refresh (1s) to keep spinner smooth and alerts responsive
while true; do
    render

    if read -rsn1 -t 1 key; then
        case "$key" in
            n) spawn_interactive ;;
            q) exit 0 ;;
            k) kill_task ;;
            d) global_diff ;;
            x) dismiss_alert ;;  # dismiss alert bar
            $'\x1b')
                read -rsn2 -t 0.1 seq || true
                case "$seq" in
                    '[A') # Up
                        [[ $SELECTED -gt 0 ]] && SELECTED=$((SELECTED - 1))
                        ;;
                    '[B') # Down
                        get_tasks
                        [[ $SELECTED -lt $((${#TASK_BRANCHES[@]} - 1)) ]] && SELECTED=$((SELECTED + 1))
                        ;;
                esac
                ;;
            '') # Enter
                jump_to_tab
                ;;
        esac
    fi
done
