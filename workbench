#!/usr/bin/env zsh
set -euo pipefail
setopt nullglob

WORKBENCH_DIR="${WORKBENCH_DIR:-$HOME/.workbench}"
WORKBENCH_SESSION="workbench"
WORKBENCH_STATE_DIR="/tmp/workbench"
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${0}" 2>/dev/null || realpath "${0}")")" && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'

usage() {
    echo -e "${BOLD}workbench${NC} — multi-agent orchestrator"
    echo ""
    echo -e "  ${CYAN}workbench start${NC}     Start a new session (or attach to existing)"
    echo -e "  ${CYAN}workbench spawn${NC}     Spawn a new task (interactive)"
    echo -e "  ${CYAN}workbench list${NC}      List active tasks"
    echo -e "  ${CYAN}workbench kill${NC}      Kill a task and clean up worktree"
    echo -e "  ${CYAN}workbench cleanup${NC}   Tear down everything"
    echo ""
    echo -e "  ${DIM}Environment:${NC}"
    echo -e "  ${DIM}  WORKBENCH_DIR     Config dir (default: ~/.workbench)${NC}"
    echo -e "  ${DIM}  WORKBENCH_REPO    Git repo root (default: current git repo)${NC}"
    echo -e "  ${DIM}  WORKBENCH_AGENT   Default agent: claude|opencode (default: claude)${NC}"
}

ensure_dirs() {
    mkdir -p "$WORKBENCH_DIR" "$WORKBENCH_STATE_DIR"
}

detect_repo() {
    if [[ -n "${WORKBENCH_REPO:-}" ]]; then
        echo "$WORKBENCH_REPO"
    else
        git rev-parse --show-toplevel 2>/dev/null || {
            echo -e "${RED}Error: Not in a git repository. Set WORKBENCH_REPO or cd into a repo.${NC}" >&2
            exit 1
        }
    fi
}

cmd_start() {
    ensure_dirs
    local repo
    repo="$(detect_repo)"

    echo -e "${PURPLE}${BOLD}⚡ workbench${NC}"
    echo -e "${DIM}repo: $repo${NC}"
    echo -e "${DIM}state: $WORKBENCH_STATE_DIR${NC}"
    echo ""

    # Store repo path for child processes
    echo "$repo" > "$WORKBENCH_STATE_DIR/.repo"

    # Check if Zellij session already exists
    if zellij list-sessions 2>/dev/null | grep -q "$WORKBENCH_SESSION"; then
        echo -e "${YELLOW}Session exists, attaching...${NC}"
        zellij attach "$WORKBENCH_SESSION"
    else
        echo -e "${GREEN}Starting new session...${NC}"
        # Launch Zellij with the orchestrator as the first tab
        zellij -s "$WORKBENCH_SESSION" \
            -n "$SCRIPT_DIR/layouts/orchestrator.kdl"
    fi
}

cmd_spawn() {
    ensure_dirs
    "$SCRIPT_DIR/wb-spawn" "$@"
}

cmd_list() {
    ensure_dirs
    if [[ ! -d "$WORKBENCH_STATE_DIR" ]] || [[ -z "$(ls -A "$WORKBENCH_STATE_DIR"/*.json 2>/dev/null)" ]]; then
        echo -e "${DIM}No active tasks.${NC}"
        return
    fi

    echo -e "${BOLD}Active tasks:${NC}"
    echo ""

    for f in "$WORKBENCH_STATE_DIR"/*.json; do
        local branch status added removed files agent
        branch="$(basename "$f" .json)"
        status="$(jq -r '.status // "unknown"' "$f")"
        added="$(jq -r '.diff_added // 0' "$f")"
        removed="$(jq -r '.diff_removed // 0' "$f")"
        files="$(jq -r '.diff_files // 0' "$f")"
        agent="$(jq -r '.agent // "unknown"' "$f")"

        local icon
        case "$status" in
            running)   icon="${GREEN}●${NC}" ;;
            prompting) icon="${YELLOW}⏳${NC}" ;;
            done)      icon="${CYAN}✓${NC}" ;;
            failed)    icon="${RED}✗${NC}" ;;
            *)         icon="${DIM}?${NC}" ;;
        esac

        printf "  %b %-30s %b%-8s%b  ${GREEN}+%-4s${NC} ${RED}-%-4s${NC} ${DIM}(%s files)${NC}  ${DIM}[%s]${NC}\n" \
            "$icon" "$branch" "$BOLD" "$status" "$NC" "$added" "$removed" "$files" "$agent"
    done
}

cmd_kill() {
    local branch="${1:-}"
    if [[ -z "$branch" ]]; then
        echo -e "${RED}Usage: workbench kill <branch>${NC}"
        exit 1
    fi
    "$SCRIPT_DIR/wb-cleanup" "$branch"
}

cmd_cleanup() {
    "$SCRIPT_DIR/wb-cleanup" --all
}

# Main
case "${1:-}" in
    start)   shift; cmd_start "$@" ;;
    spawn)   shift; cmd_spawn "$@" ;;
    list)    shift; cmd_list "$@" ;;
    kill)    shift; cmd_kill "$@" ;;
    cleanup) shift; cmd_cleanup "$@" ;;
    -h|--help|help|"") usage ;;
    *) echo -e "${RED}Unknown command: $1${NC}"; usage; exit 1 ;;
esac
