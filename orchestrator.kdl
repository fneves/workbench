layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
    }

    tab name="⚡ orchestrator" focus=true {
        pane command="bash" {
            args "-c" "wb-status || echo 'wb-status not found in PATH. Run it manually.'; exec bash"
        }
    }
}
