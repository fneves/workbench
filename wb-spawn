#!/usr/bin/env bash
set -euo pipefail

WORKBENCH_STATE_DIR="/tmp/workbench"
WORKBENCH_SESSION="workbench"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

usage() {
    echo -e "Usage: wb-spawn [options]"
    echo ""
    echo -e "  ${CYAN}-b, --branch${NC}   Branch name (required)"
    echo -e "  ${CYAN}-p, --prompt${NC}   Task prompt for the agent"
    echo -e "  ${CYAN}-a, --agent${NC}    Agent to use: claude|opencode (default: claude)"
    echo -e "  ${CYAN}-m, --mode${NC}     Execution mode: worktree|container (default: worktree)"
    echo -e "  ${CYAN}-f, --from${NC}     Base branch to create worktree from (default: main)"
    echo -e "  ${CYAN}-i, --interactive${NC}  Interactive mode (no prompt, just open agent)"
    echo ""
    echo -e "  ${DIM}Example:${NC}"
    echo -e "  ${DIM}  wb-spawn -b fix-throttle -p 'Fix the SQL console throttling issue' -a claude${NC}"
}

BRANCH=""
PROMPT=""
AGENT="${WORKBENCH_AGENT:-claude}"
MODE="worktree"
BASE_BRANCH="main"
INTERACTIVE=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -b|--branch)  BRANCH="$2"; shift 2 ;;
        -p|--prompt)  PROMPT="$2"; shift 2 ;;
        -a|--agent)   AGENT="$2"; shift 2 ;;
        -m|--mode)    MODE="$2"; shift 2 ;;
        -f|--from)    BASE_BRANCH="$2"; shift 2 ;;
        -i|--interactive) INTERACTIVE=true; shift ;;
        -h|--help)    usage; exit 0 ;;
        *)            echo -e "${RED}Unknown option: $1${NC}"; usage; exit 1 ;;
    esac
done

if [[ -z "$BRANCH" ]]; then
    echo -e "${RED}Error: --branch is required${NC}"
    usage
    exit 1
fi

# Resolve paths
REPO_ROOT="$(cat "$WORKBENCH_STATE_DIR/.repo" 2>/dev/null || git rev-parse --show-toplevel)"
WORKTREE_DIR="$REPO_ROOT/.worktrees/$BRANCH"
STATE_FILE="$WORKBENCH_STATE_DIR/$BRANCH.json"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LAYOUTS_DIR="$WORKBENCH_STATE_DIR/layouts"

mkdir -p "$LAYOUTS_DIR"

# ============================================================
# 1. Create worktree
# ============================================================
if [[ "$MODE" == "worktree" ]]; then
    if [[ -d "$WORKTREE_DIR" ]]; then
        echo -e "${YELLOW}Worktree already exists: $WORKTREE_DIR${NC}"
    else
        echo -e "${GREEN}Creating worktree: $BRANCH (from $BASE_BRANCH)${NC}"
        mkdir -p "$REPO_ROOT/.worktrees"
        git -C "$REPO_ROOT" worktree add "$WORKTREE_DIR" -b "$BRANCH" "$BASE_BRANCH" 2>/dev/null || \
        git -C "$REPO_ROOT" worktree add "$WORKTREE_DIR" "$BRANCH" 2>/dev/null || {
            echo -e "${RED}Failed to create worktree${NC}"
            exit 1
        }
    fi
elif [[ "$MODE" == "container" ]]; then
    echo -e "${YELLOW}Container mode — setting up worktree + devcontainer: $BRANCH${NC}"
    if [[ ! -d "$WORKTREE_DIR" ]]; then
        mkdir -p "$REPO_ROOT/.worktrees"
        git -C "$REPO_ROOT" worktree add "$WORKTREE_DIR" -b "$BRANCH" "$BASE_BRANCH" 2>/dev/null || \
        git -C "$REPO_ROOT" worktree add "$WORKTREE_DIR" "$BRANCH"
    fi
fi

# ============================================================
# 2. Initialize state file
# ============================================================
NOW="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
cat > "$STATE_FILE" <<EOF
{
  "branch": "$BRANCH",
  "status": "starting",
  "agent": "$AGENT",
  "mode": "$MODE",
  "worktree": "$WORKTREE_DIR",
  "prompt": $(echo "$PROMPT" | jq -Rs .),
  "diff_added": 0,
  "diff_removed": 0,
  "diff_files": 0,
  "created_at": "$NOW",
  "updated_at": "$NOW",
  "pid": null
}
EOF

# ============================================================
# 3. Write the agent wrapper script
# ============================================================
WRAPPER_FILE="$WORKBENCH_STATE_DIR/$BRANCH.run.sh"
cat > "$WRAPPER_FILE" <<'WRAPPER_HEADER'
#!/usr/bin/env bash
set -uo pipefail
WRAPPER_HEADER

cat >> "$WRAPPER_FILE" <<WRAPPER_VARS
STATE_FILE="$STATE_FILE"
WORKTREE_DIR="$WORKTREE_DIR"
BRANCH="$BRANCH"
WRAPPER_VARS

cat >> "$WRAPPER_FILE" <<'WRAPPER_BODY'

update_state() {
    local key="$1" value="$2"
    local tmp
    tmp="$(mktemp)"
    jq --arg k "$key" --arg v "$value" \
        '.[$k] = $v | .updated_at = (now | todate)' \
        "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

update_diff_stats() {
    local summary
    summary="$(cd "$WORKTREE_DIR" && git diff --shortstat HEAD 2>/dev/null || echo "")"
    local files=0 added=0 removed=0
    if [[ -n "$summary" ]]; then
        files=$(echo "$summary" | grep -oE '[0-9]+ file'       | grep -oE '[0-9]+' || echo 0)
        added=$(echo "$summary" | grep -oE '[0-9]+ insertion'  | grep -oE '[0-9]+' || echo 0)
        removed=$(echo "$summary" | grep -oE '[0-9]+ deletion' | grep -oE '[0-9]+' || echo 0)
    fi
    local tmp
    tmp="$(mktemp)"
    jq --argjson f "${files:-0}" --argjson a "${added:-0}" --argjson r "${removed:-0}" \
        '.diff_files = $f | .diff_added = $a | .diff_removed = $r | .updated_at = (now | todate)' \
        "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

notify() {
    local title="$1" body="$2"
    if command -v notify-send &>/dev/null; then
        notify-send "$title" "$body"
    elif command -v osascript &>/dev/null; then
        osascript -e "display notification \"$body\" with title \"$title\""
    fi
    printf "\a"  # terminal bell
}

# --- Background diff stat updater (every 3s) ---
(
    while true; do
        sleep 3
        [[ -f "$STATE_FILE" ]] || break
        update_diff_stats
    done
) &
DIFF_PID=$!
trap 'kill $DIFF_PID 2>/dev/null' EXIT

# --- Mark as running ---
cd "$WORKTREE_DIR"
update_state "status" "running"
update_state "pid" "$$"

echo ""
echo -e "\033[0;35m\033[1m⚡ workbench\033[0m — $BRANCH"
echo -e "\033[2m   worktree: $WORKTREE_DIR\033[0m"
echo ""
WRAPPER_BODY

# Inject the actual agent command
case "$AGENT" in
    claude)
        if [[ "$INTERACTIVE" == true ]] || [[ -z "$PROMPT" ]]; then
            echo 'claude' >> "$WRAPPER_FILE"
        else
            # Safely embed the prompt
            ESCAPED_PROMPT="$(printf '%s' "$PROMPT" | sed "s/'/'\\\\''/g")"
            echo "claude '${ESCAPED_PROMPT}'" >> "$WRAPPER_FILE"
        fi
        ;;
    opencode)
        echo 'opencode' >> "$WRAPPER_FILE"
        ;;
    *)
        echo -e "${RED}Unknown agent: $AGENT${NC}"
        exit 1
        ;;
esac

cat >> "$WRAPPER_FILE" <<'WRAPPER_FOOTER'
EXIT_CODE=$?

# --- Finalize ---
update_diff_stats

if [[ $EXIT_CODE -eq 0 ]]; then
    update_state "status" "done"
    notify "✓ $BRANCH" "Agent finished successfully"
else
    update_state "status" "failed"
    notify "✗ $BRANCH" "Agent exited with code $EXIT_CODE"
fi

echo ""
echo -e "\033[2mAgent exited ($EXIT_CODE). You're still in the worktree. Ctrl+D to close.\033[0m"
exec bash --norc --noprofile
WRAPPER_FOOTER

chmod +x "$WRAPPER_FILE"

# ============================================================
# 4. Write the watcher launch script
# ============================================================
WATCHER_FILE="$WORKBENCH_STATE_DIR/$BRANCH.watch.sh"
cat > "$WATCHER_FILE" <<WATCHER
#!/usr/bin/env bash
exec "$SCRIPT_DIR/wb-watch" "$WORKTREE_DIR" "$BRANCH"
WATCHER
chmod +x "$WATCHER_FILE"

# ============================================================
# 5. Generate a per-task Zellij layout (.kdl) with commands
# ============================================================
TASK_LAYOUT="$LAYOUTS_DIR/$BRANCH.kdl"

if [[ "$MODE" == "container" ]]; then
    # Container mode: devcontainer up, then exec the wrapper inside it
    cat > "$TASK_LAYOUT" <<KDL
layout {
    pane split_direction="vertical" {
        pane size="60%" name="agent" focus=true command="bash" {
            args "-c" "echo 'Starting devcontainer for $BRANCH...'; cd '$WORKTREE_DIR' && devcontainer up --workspace-folder . && devcontainer exec --workspace-folder . bash '$WRAPPER_FILE'; exec bash"
        }
        pane size="40%" name="watcher" command="bash" {
            args "-c" "exec bash '$WATCHER_FILE'"
        }
    }
}
KDL
else
    # Worktree mode: run wrapper directly
    cat > "$TASK_LAYOUT" <<KDL
layout {
    pane split_direction="vertical" {
        pane size="60%" name="agent" focus=true command="bash" {
            args "-c" "exec bash '$WRAPPER_FILE'"
        }
        pane size="40%" name="watcher" command="bash" {
            args "-c" "exec bash '$WATCHER_FILE'"
        }
    }
}
KDL
fi

echo -e "${DIM}Layout:  $TASK_LAYOUT${NC}"
echo -e "${DIM}Agent:   $WRAPPER_FILE${NC}"
echo -e "${DIM}Watcher: $WATCHER_FILE${NC}"

# ============================================================
# 6. Launch in Zellij
# ============================================================
if [[ -n "${ZELLIJ:-}" ]] || [[ -n "${ZELLIJ_SESSION_NAME:-}" ]]; then
    # Inside Zellij — create a new tab with the generated layout
    echo -e "${GREEN}Creating Zellij tab: $BRANCH${NC}"
    zellij action new-tab --name "$BRANCH" --layout "$TASK_LAYOUT"

    echo ""
    echo -e "${GREEN}${BOLD}✓ Task spawned: $BRANCH${NC}"
    echo -e "  ${DIM}Worktree:  $WORKTREE_DIR${NC}"
    echo -e "  ${DIM}Agent:     $AGENT${NC}"
    echo -e "  ${DIM}Mode:      $MODE${NC}"
    if [[ -n "$PROMPT" ]]; then
        echo -e "  ${DIM}Prompt:    ${PROMPT:0:80}${NC}"
    else
        echo -e "  ${DIM}Prompt:    (interactive)${NC}"
    fi

elif zellij list-sessions 2>/dev/null | grep -q "$WORKBENCH_SESSION"; then
    # Not inside Zellij but the session exists — pipe the action in
    echo -e "${YELLOW}Injecting tab into existing session...${NC}"
    zellij --session "$WORKBENCH_SESSION" action new-tab --name "$BRANCH" --layout "$TASK_LAYOUT" 2>/dev/null || {
        echo -e "${YELLOW}Could not inject remotely. Attach and spawn from inside:${NC}"
        echo -e "  ${CYAN}zellij attach $WORKBENCH_SESSION${NC}"
        echo -e "  then: ${CYAN}wb-spawn -b $BRANCH ...${NC}"
    }
    echo -e "${GREEN}${BOLD}✓ Task spawned: $BRANCH${NC}"
    echo -e "${DIM}Attach with: zellij attach $WORKBENCH_SESSION${NC}"

else
    echo -e "${YELLOW}Not inside Zellij and no session found.${NC}"
    echo ""
    echo -e "  ${BOLD}Option 1:${NC} Start workbench first"
    echo -e "    ${CYAN}workbench start${NC}"
    echo ""
    echo -e "  ${BOLD}Option 2:${NC} Run standalone (no Zellij)"
    echo -e "    ${DIM}# Terminal 1 — agent${NC}"
    echo -e "    ${CYAN}bash $WRAPPER_FILE${NC}"
    echo -e "    ${DIM}# Terminal 2 — watcher${NC}"
    echo -e "    ${CYAN}bash $WATCHER_FILE${NC}"
fi
